<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Tema base do aplicativo.
        Herda de Theme.AppCompat.Light.DarkActionBar para compatibilidade
        com API 17 (Android 4.2) em diante.
    -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/background_main</item>
    </style>

    <!--
        Tema para a ConfiguracaoActivity (sem alteração visual,
        mas declarado explicitamente para facilitar customizações futuras).
    -->
    <style name="AppTheme.Configuracao" parent="AppTheme" />

</resources>
