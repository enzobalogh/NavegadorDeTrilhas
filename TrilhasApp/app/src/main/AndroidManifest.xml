<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.trilhasapp">

    <!-- Permissões necessárias para rastreamento de trilhas -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <!-- MainActivity: tela inicial do aplicativo -->
        <activity
            android:name=".activities.MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ConfiguracaoActivity: tela de configurações -->
        <activity
            android:name=".activities.ConfiguracaoActivity"
            android:exported="false"
            android:label="@string/title_configuracoes"
            android:parentActivityName=".activities.MainActivity" />

        <!-- RegistrarTrilhaActivity: será implementada na Parte 2 -->
        <!-- <activity android:name=".activities.RegistrarTrilhaActivity" /> -->

        <!-- ConsultarTrilhasActivity: será implementada na Parte 2 -->
        <!-- <activity android:name=".activities.ConsultarTrilhasActivity" /> -->

    </application>

</manifest>
